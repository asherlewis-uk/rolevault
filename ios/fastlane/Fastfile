default_platform(:ios)

before_all do
  # Ensure Swift is available and meets minimum requirements
  swift_version = sh("swift", "--version", error_callback: ->(_cmd, _status, _output) {
    UI.user_error!("Swift is not installed or not in PATH. Run ./setup-swiftly.sh first.")
  })
  UI.success("Swift toolchain verified:\n#{swift_version}")

  # Verify xcodegen is available when needed
  unless ENV['SKIP_XCODEGEN_CHECK']
    sh("which", "xcodegen", error_callback: ->(_cmd, _status, _output) {
      UI.important("xcodegen not found in PATH. Install via: brew install xcodegen")
    })
  end
end

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    ensure_git_status_clean

    increment_build_number(xcodeproj: "RoleVault.xcodeproj")

    build_app(
      scheme: "RoleVault",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates",
      output_directory: "build"
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      notify_external_testers: false
    )
  end

  desc "Build local debug IPA"
  lane :build_debug do
    build_app(
      scheme: "RoleVault",
      export_method: "development",
      configuration: "Debug",
      output_directory: "build"
    )
  end
end
